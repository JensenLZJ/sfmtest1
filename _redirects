# Redirect map (GitHub Pages compatible)
# GitHub Pages does not support server redirects. These rules are implemented
# in 404.html via client-side redirects when a path 404s.
#
# Format: path -> target (redirect)
# Clean URLs (no .html) -> serve .html so the page loads
/about          -> /about.html
/contact        -> /contact.html
/schedule       -> /schedule.html
/team           -> /team.html
/opportunities  -> /opportunities.html
/privacy-policy -> /privacy-policy.html
/request        -> /request.html
/brand          -> /brand.html
/apply          -> /opportunities.html
